{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 0,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "temperature", "custom/gpu", "disk", "network", "pulseaudio", "battery"],

    "hyprland/workspaces": {
        "format": "{id}"
    },
    "hyprland/window": {
        "max-length": 50,
        "separate-outputs": true
    },

    "clock": {
        "format": "َ°…گ {:%H:%M  آ·  %a %d %b}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 2,
        "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency}GHz"
    },
    "memory": {
        "format": "َ°چ› {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G ({percentage}%)",
        "interval": 5
    },
    "temperature": {
        "format": "َ°”„ {temperatureC}آ°C",
        "critical-threshold": 80,
        "format-critical": "َ°¸پ {temperatureC}آ°C"
    },
    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used,memory.total --format=csv,noheader,nounits | awk -F', ' '{printf \"%s%% %sآ°C %sMB/%sMB\", $1, $2, $3, $4}'",
        "format": "َ°¾² {}",
        "interval": 3,
        "tooltip": false
    },
    "disk": {
        "format": "َ°‹ٹ {percentage_used}%",
        "tooltip-format": "{used} / {total} ({percentage_used}%) em {path}",
        "path": "/"
    },
    "network": {
        "format-wifi": "َ°¤¨ {essid}  â†“{bandwidthDownBytes} â†‘{bandwidthUpBytes}",
        "format-ethernet": "َ°ˆ€ {ifname}  â†“{bandwidthDownBytes} â†‘{bandwidthUpBytes}",
        "format-disconnected": "َ°¤­ desconectado",
        "interval": 2,
        "tooltip-format": "{ipaddr} via {gwaddr}\n{signalStrength}% sinal"
    },
    "pulseaudio": {
        "format": "َ°•¾ {volume}%",
        "format-muted": "َ°‌ں mudo",
        "on-click": "pavucontrol"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "{capacity}% â€” {timeTo}",
        "states": {
            "warning": 30,
            "critical": 15
        }
    }
}
